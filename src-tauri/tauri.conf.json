{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeChat Analyzer",
  "version": "0.1.0",
  "identifier": "com.klesen.chat-analyzer",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:8899"
  },
  "app": {
    "windows": [
      {
        "title": "微信聊天分析器",
        "width": 1100,
        "height": 750,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist/chat-analyzer-backend",
      "../dist/wx",
      "../templates/index.html",
      "../templates/vendor/chart.min.js",
      "../templates/vendor/html2canvas.min.js",
      "../templates/vendor/pinyin-pro.js",
      "../config.json"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
